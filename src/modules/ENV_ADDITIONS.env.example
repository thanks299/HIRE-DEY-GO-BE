# ─── Sprint 8 & 9 — New env vars ───────────────────────────────
# Add these to your .env and Render environment settings

# Cloudinary (for company logos + CV uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Anthropic (for CV parsing)
ANTHROPIC_API_KEY=sk-ant-...
